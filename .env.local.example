# CIR Diagnostic Engine — Environment Variables
# Set at least ONE provider to enable the engine.
# Multiple providers enable the fallback router and cross-provider stability checks.

# Priority 1 — Mistral (strong analytical capability, generous free tier)
# Free Experiment plan: console.mistral.ai — phone verification required
MISTRAL_API_KEY=

# Priority 2 — Google Gemini (1M context, 1,500 req/day free, fast)
# Free API key: ai.google.dev
GEMINI_API_KEY=

# Priority 3 — Groq (fast inference, 30 req/min free, Llama 3.3 70B)
# Free API key: console.groq.com
GROQ_API_KEY=

# Priority 4 — OpenRouter (Qwen3 235B free tier, $1 credit on signup)
# Free API key: openrouter.ai
OPENROUTER_API_KEY=

# Priority 5 — NVIDIA NIM (DeepSeek R1 free, no credit card required)
# Free API key (nvapi-...): build.nvidia.com
NVIDIA_API_KEY=

# NOTES:
# - No API key requires a credit card on signup for free tier usage
# - The engine operates with any single provider — multiple providers enable
#   cross-provider disagreement detection and stability assessment
# - The @anthropic-ai/sdk dependency has been removed — all providers use fetch()
# - Provider weights are held in memory and reset on cold start (acceptable for MVP)
